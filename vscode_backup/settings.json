{
    "[dockercompose]": {
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.insertSpaces": true,
        "editor.quickSuggestions": {
            "comments": false,
            "other": true,
            "strings": true
        },
        "editor.tabSize": 4
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.detectIndentation": false,
        "editor.formatOnSave": true,
        "editor.insertSpaces": true,
        "editor.tabSize": 4
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.detectIndentation": false,
        "editor.formatOnSave": true,
        "editor.insertSpaces": true,
        "editor.tabSize": 4
    },
    "[log]": {},
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one",
        "editor.formatOnSave": true
    },
    "[python]": {
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "never",
            "source.organizeImports.ruff": "never"
        },
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": false,
        "editor.formatOnType": false
    },
    "[toml]": {
        "editor.defaultFormatter": "tamasfe.even-better-toml",
        "editor.formatOnSave": true
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.formatOnSave": true
    },
    "chat.editor.fontFamily": "'CaskaydiaCove Nerd Font', Consolas, 'Courier New'",
    "chat.editor.fontSize": 14,
    "chat.editor.fontWeight": "300",
    "debug.console.fontFamily": "'CaskaydiaCove Nerd Font', Consolas, 'Courier New'",
    "debug.console.fontSize": 14,
    "debug.console.wordWrap": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "docker.extension.enableComposeLanguageServer": false,
    "editor.accessibilitySupport": "off",
    "editor.autoClosingBrackets": "never",
    "editor.autoClosingComments": "never",
    "editor.autoClosingDelete": "never",
    "editor.bracketPairColorization.enabled": true,
    "editor.bracketPairColorization.independentColorPoolPerBracketType": false,
    "editor.codeLensFontFamily": "'CaskaydiaCove Nerd Font', Consolas, 'Courier New'",
    "editor.cursorStyle": "line",
    "editor.detectIndentation": false,
    "editor.folding": true,
    "editor.fontFamily": "'CaskaydiaCove Nerd Font', Consolas, 'Courier New'",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.fontWeight": "300",
    "editor.formatOnSave": false,
    "editor.hover.delay": 200,
    "editor.hover.enabled": "on",
    "editor.inlayHints.fontFamily": "'CaskaydiaCove Nerd Font', Consolas, 'Courier New'",
    "editor.inlineSuggest.fontFamily": "'CaskaydiaCove Nerd Font', Consolas, 'Courier New'",
    "editor.lineHeight": 24,
    "editor.maxTokenizationLineLength": 2000000,
    "editor.minimap.enabled": false,
    "editor.mouseWheelScrollSensitivity": 1.0,
    "editor.parameterHints.enabled": true,
    "editor.renderWhitespace": "boundary",
    "editor.rulers": [
        119,
        120
    ],
    "editor.scrollbar.horizontalScrollbarSize": 14,
    "editor.scrollbar.verticalScrollbarSize": 14,
    "explorer.confirmDelete": false,
    "explorer.decorations.badges": false,
    "explorer.incrementalNaming": "simple",
    "extensions.autoUpdate": true,
    "extensions.ignoreRecommendations": true,
    "files.associations": {
        "docker-compose*.yml": "yaml"
    },
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 500,
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "git.openRepositoryInParentFolders": "always",
    "interactiveWindow.executeWithShiftEnter": true,
    "jupyter.askForKernelRestart": false,
    "markdown.extension.tableFormatter.delimiterRowNoPadding": false,
    "markdown.extension.tableFormatter.enabled": true,
    "markdown.extension.tableFormatter.normalizeIndentation": true,
    "markdown.preview.fontSize": 14,
    "notebook.compactView": true,
    "notebook.lineNumbers": "on",
    "notebook.markup.fontFamily": "'CaskaydiaCove Nerd Font', Consolas, 'Courier New'",
    "notebook.markup.fontSize": 14,
    "notebook.output.fontFamily": "'CaskaydiaCove Nerd Font', Consolas, 'Courier New'",
    "notebook.output.fontSize": 14,
    "notebook.output.wordWrap": false,
    "python.analysis.autoImportCompletions": false,
    "python.analysis.autoSearchPaths": false,
    "python.analysis.diagnosticSeverityOverrides": {
        "reportArgumentType": "none",
        "reportAttributeAccessIssue": "none",
        "reportCallIssue": "none",
        "reportGeneralTypeIssues": "none",
        "reportIncompatibleVariableOverride": "none",
        "reportIndexIssue": "none",
        "reportMissingImports": "none",
        "reportMissingModuleSource": "none",
        "reportOperatorIssue": "none",
        "reportOptionalCall": "none",
        "reportOptionalIterable": "none",
        "reportOptionalMemberAccess": "none",
        "reportOptionalSubscript": "none",
        "reportPrivateUsage": "none",
        "reportUnusedFunction": "none",
        "reportUnusedImport": "none",
        "reportUnusedVariable": "none"
    },
    "python.analysis.enablePytestSupport": true,
    "python.analysis.gotoDefinitionInStringLiteral": true,
    "python.analysis.indexing": true,
    "python.analysis.inlayHints.callArgumentNames": "partial",
    "python.analysis.inlayHints.functionReturnTypes": false,
    "python.analysis.inlayHints.pytestParameters": true,
    "python.analysis.logLevel": "Information",
    "python.analysis.typeCheckingMode": "basic",
    "python.defaultInterpreterPath": "",
    "python.experiments.optInto": [
        "pythonTestAdapter"
    ],
    "python.languageServer": "Pylance",
    "python.terminal.activateEnvInCurrentTerminal": false,
    "python.terminal.activateEnvironment": false,
    "python.terminal.executeInFileDir": false,
    "python.testing.autoTestDiscoverOnSaveEnabled": true,
    "python.testing.cwd": "${workspaceFolder}",
    "python.testing.promptToConfigure": false,
    "python.testing.pytestArgs": [
        "--rootdir",
        "${workspaceFolder}",
        "--verbose",
        "--maxfail=1",
        "--cache-clear"
    ],
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "redhat.telemetry.enabled": false,
    "remote.autoForwardPortsSource": "hybrid",
    "ruff.enable": true,
    "ruff.fixAll": false,
    "ruff.importStrategy": "fromEnvironment",
    "ruff.lint.enable": true,
    "ruff.organizeImports": true,
    "ruff.showSyntaxErrors": true,
    "scm.countBadge": "all",
    "scm.inputFontFamily": "'CaskaydiaCove Nerd Font', Consolas, 'Courier New'",
    "scm.inputFontSize": 14,
    "terminal.integrated.cwd": "${workspaceFolder}",
    "terminal.integrated.fontFamily": "'CaskaydiaCove Nerd Font', Consolas, 'Courier New'",
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.mouseWheelScrollSensitivity": 0.5,
    "testing.alwaysRevealTestOnStateChange": true,
    "testing.defaultGutterClickAction": "debug",
    "testing.gutterEnabled": true,
    "testing.showAllMessages": true,
    "window.newWindowDimensions": "maximized",
    "window.restoreFullscreen": true,
    "window.title": "${rootName}",
    "workbench.activityBar.location": "bottom",
    "workbench.colorTheme": "Kanagawa Wave",
    "workbench.editor.enablePreview": false,
    "workbench.editor.labelFormat": "short",
    "workbench.list.mouseWheelScrollSensitivity": 0.5,
    "workbench.secondarySideBar.showLabels": false,
    "workbench.settings.applyToAllProfiles": [
        "editor.fontFamily"
    ],
    "yaml.format.bracketSpacing": true,
    "yaml.format.enable": true,
    "yaml.format.singleQuote": true,
    "zenMode.centerLayout": false,
    "zenMode.fullScreen": false,
    "zenMode.hideLineNumbers": false,
    "zenMode.hideStatusBar": false,
    "zenMode.silentNotifications": false,
    "window.commandCenter": false,
    "workbench.sideBar.location": "right",
    "workbench.iconTheme": "material-icon-theme",
    "material-icon-theme.folders.color": "#42a5f5",
    "material-icon-theme.rootFolders.color": "#90a4ae",
    "material-icon-theme.opacity": 1,
    "material-icon-theme.saturation": 1,
    "material-icon-theme.files.color": "#42a5f5",
    "vim.easymotion": true,
    "vim.incsearch": true,
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,
    "vim.hlsearch": true,
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "j"
            ],
            "after": [
                "<Esc>"
            ]
        }
    ],
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<leader>",
                "d"
            ],
            "after": [
                "d",
                "d"
            ]
        },
        {
            "before": [
                "<C-n>"
            ],
            "commands": [
                ":nohl"
            ]
        },
        {
            "before": [
                "K"
            ],
            "commands": [
                "lineBreakInsert"
            ],
            "silent": true
        }
    ],
    "vim.leader": "<space>",
    "vim.handleKeys": {
        "<C-a>": false,
        "<C-f>": false
    },
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    }
}
